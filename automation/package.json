{
  "name": "versebyverse-qa-automation",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright API and E2E automation for the VerseByVerse QA portfolio.",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:api:report": "playwright test --project=api",
    "test:preflight": "playwright test api-tests/00-preflight.api.spec.js --project=api",
    "test:notes": "playwright test api-tests/notes.api.spec.js --project=api",
    "test:community": "playwright test api-tests/community.api.spec.js api-tests/community-posts.api.spec.js --project=api",
    "test:e2e": "playwright test --project=chromium",
    "test:headed": "playwright test --project=chromium --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "dotenv": "^16.4.7"
  }
}
